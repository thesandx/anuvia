# Copy this to .env.docker and fill in real values.
# .env.docker is git-ignored — never commit it.
#
# This file is used for local Docker testing against Neon (production-like).
# For normal local dev (SQLite, no Docker), use .env instead.

APP_NAME=anuvia
APP_ENV=production
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Neon PostgreSQL — see README "Setting Up Neon" for how to build this string
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb

# Stripe (leave empty if not using)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
