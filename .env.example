APP_NAME=anuvia
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Local development — SQLite, no setup needed
DATABASE_URL=sqlite+aiosqlite:///./local.db

# Production — Neon PostgreSQL (copy the connection string from your Neon dashboard)
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
