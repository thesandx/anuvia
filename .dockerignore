# Never bake secrets into the image
.env
.env.local
.env.*.local
.env.docker

# No need to copy — pip installs these inside the image
.venv/
venv/
env/

# SQLite databases
*.db
*.db-shm
*.db-wal

# Caches and build artifacts
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# macOS / IDE
.DS_Store
.idea/
.vscode/

# Git
.git/
.gitignore
